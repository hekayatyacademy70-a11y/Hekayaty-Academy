{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/src/app.ts",
      "use": "@vercel/node"
    },
    {
      "src": "artifacts/hekayaty-academy/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/artifacts/api-server/src/app.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/artifacts/hekayaty-academy/$1"
    }
  ]
}
