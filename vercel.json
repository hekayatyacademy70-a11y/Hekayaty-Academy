{
  "version": 2,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/hekayaty-academy/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "api/*.mjs"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.mjs"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

