# =============================================================
# Hekayaty Academy — Environment Variables Template
# Copy this to .env and fill in the values
# =============================================================

# ---- Supabase PostgreSQL (via Drizzle ORM) ------------------
# Find this in: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.lynrxzgqxmrhzspvelyd:YOUR_DB_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ---- Supabase API Keys --------------------------------------
SUPABASE_URL=https://lynrxzgqxmrhzspvelyd.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ---- Express API Server -------------------------------------
PORT=3000
NODE_ENV=development

# ---- JWT Auth (generate strong secrets for production) ------
JWT_SECRET=<generate-with: openssl rand -base64 64>
JWT_REFRESH_SECRET=<generate-with: openssl rand -base64 64>

# ---- Cloudflare R2 (fill when setting up file uploads) ------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hekayaty-academy
R2_PUBLIC_URL=https://pub-xxx.r2.dev
